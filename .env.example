# Project Details
PROJECT_NAME="AI-Powered Eyewear OMS"

# Database Configuration
# Use local sqlite file for quick development fallback, or PostgreSQL for production:
DATABASE_URL=postgresql+psycopg2://postgres:postgres_secure_pw@postgres:5432/eyewear_oms

# Redis Cache and Event Streams Connection
REDIS_URL=redis://redis:6379/0

# Security (HS256 JWT validation)
JWT_SECRET=super_secret_jwt_signing_key_change_me_in_production_1234567890

# Razorpay Integration
RAZORPAY_KEY_ID=rzp_test_mockkeyid123
RAZORPAY_SECRET=mocksecretkey1234567890

# SMTP E-Mail Server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@eyewearoms.com
SMTP_PASSWORD=mockpassword123
SMTP_FROM_EMAIL=no-reply@eyewearoms.com

# Twilio WhatsApp/SMS API Senders
TWILIO_ACCOUNT_SID=ACmockaccountsid123456
TWILIO_AUTH_TOKEN=mockauthtoken12345678
TWILIO_FROM_NUMBER=+1234567890

# Media Upload Storage
AWS_ACCESS_KEY_ID=mockaccesskey
AWS_SECRET_ACCESS_KEY=mocksecretkey
AWS_S3_BUCKET=eyewear-oms-media
CLOUDINARY_URL=
